# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ---- LLM provider: pick ONE ------------------------------------------------
# claude-sdk  -> NO API key needed. Reuses the `claude` CLI session stored in
#               ~/.claude. Requires Claude Code installed + `claude login` done.
#               Ideal for local POC / Enterprise subscription users.
# anthropic   -> API key required. Use this on the control node in production.
LLM_PROVIDER=claude-sdk           # claude-sdk | anthropic | openai | gemini

# ANTHROPIC_API_KEY=sk-ant-...   # needed only when LLM_PROVIDER=anthropic
# OPENAI_API_KEY=sk-proj-...     # needed only when LLM_PROVIDER=openai
# GEMINI_API_KEY=...             # needed only when LLM_PROVIDER=gemini

# Optional: pin a specific model (omit to use the CLI/provider default)
LLM_MODEL=claude-sonnet-5
# LLM_MODEL=gpt-4.1
# LLM_MODEL=gemini-2.5-flash

# ---- Target VM ------------------------------------------------------------
TARGET_HOST=172.16.0.9            # private IP of the RHEL/Oracle Linux target
SSH_USER=aiagent
SSH_KEY=~/.ssh/id_rsa
HEALTH_URL=http://localhost/health
# JUMP_HOST=user@bastion-ip       # set if target is behind a bastion host

# ---- Execution mode -------------------------------------------------------
# DRY_RUN=1  -> prints the Ansible command instead of running it (safe for local dev)
# DRY_RUN=0  -> real patching via Ansible (use this on the control node)
DRY_RUN=1

# ---- Trivy ----------------------------------------------------------------
TRIVY_PATH=/usr/local/bin/trivy
REMOTE_REPORT_PATH=/tmp/trivy_scan.json

# ---- Cadence / paths ------------------------------------------------------
REPORT_PATH=~/incoming/scan.json
WATCH_INTERVAL=30
SCAN_INTERVAL=3600

# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ---- LLM provider: pick ONE and set its matching key ----------------------
LLM_PROVIDER=anthropic            # anthropic | openai | gemini

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# GEMINI_API_KEY=...

# Optional: pin a specific model (else a per-provider default is used)
LLM_MODEL=claude-sonnet-5
# LLM_MODEL=gpt-4.1
# LLM_MODEL=gemini-2.5-flash

# ---- Target VM ------------------------------------------------------------
TARGET_HOST=172.16.0.9            # private IP of the RHEL/Oracle Linux target
SSH_USER=aiagent
SSH_KEY=~/.ssh/id_rsa
HEALTH_URL=http://localhost/health
# JUMP_HOST=user@bastion-ip       # set if target is behind a bastion host

# ---- Execution mode -------------------------------------------------------
# DRY_RUN=1  -> prints the Ansible command instead of running it (safe for local dev)
# DRY_RUN=0  -> real patching via Ansible (use this on the control node)
DRY_RUN=1

# ---- Trivy ----------------------------------------------------------------
TRIVY_PATH=/usr/local/bin/trivy
REMOTE_REPORT_PATH=/tmp/trivy_scan.json

# ---- Cadence / paths ------------------------------------------------------
REPORT_PATH=~/incoming/scan.json
WATCH_INTERVAL=30
SCAN_INTERVAL=3600
